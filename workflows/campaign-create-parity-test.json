      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const emailAccount = $(\"Get Email Account\").first().json;\nconst contact = $(\"Get One Contact\").first().json;\nconst contactId = contact.contactId || contact.id;\nif (!contactId) {\n  throw new Error('No saved contact found. Save at least one contact in Seamless first.');\n}\nconst emailAccountId = emailAccount.emailAccountId || emailAccount.id;\nif (!emailAccountId) {\n  throw new Error('No email account found for jon@seamlesscontacts.com');\n}\nconst ts = new Date().toISOString().replace(/[:.]/g, '-');\nreturn [{\n  json: {\n    campaignName: `n8n Campaign Parity Test ${ts}`,\n    emailAccountId: String(emailAccountId),\n    contactIds: String(contactId),\n  },\n}];"
      },
      "executeOnce": true
    },
    {
      "id": "11111111-1111-4111-8111-111111111105",
