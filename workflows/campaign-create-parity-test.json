              "type": "custom",
              "name": "Intro Task",
              "dueDay": 1,
              "description": "Parity test custom step"
            },
            {
              "type": "manual-email",
              "name": "Follow-up Email",
              "dueDay": 3,
              "templateData": {
                "value": {
