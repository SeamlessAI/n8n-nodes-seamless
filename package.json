{
	"name": "n8n-nodes-seamless",
	"version": "0.1.0",
	"description": "n8n community nodes for Seamless.ai — REST API and trigger",
	"license": "MIT",
	"type": "commonjs",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"homepage": "https://seamless.ai",
	"author": "Seamless",
	"repository": {
		"type": "git",
		"url": "https://github.com/SeamlessAI/n8n-nodes-seamless"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"seamless"
	],
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "eslint && n8n-node lint",
		"lint:fix": "eslint --fix && n8n-node lint --fix",
		"precommit": "lint-staged"
	},
	"lint-staged": {
		"*.ts": [
			"eslint --fix"
		]
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": "1",
		"credentials": [
			"dist/credentials/SeamlessApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Seamless/Seamless.node.js",
			"dist/nodes/Seamless/SeamlessTrigger.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": ">=1.120.0"
	},
	"devDependencies": {
		"@n8n/node-cli": "0.23.1",
		"@types/node": "25.6.0",
		"eslint": "10.2.0",
		"eslint-plugin-n8n-nodes-base": "1.16.6",
		"globals": "17.5.0",
		"lint-staged": "16.4.0",
		"n8n-workflow": "2.13.1",
		"prettier": "3.8.3",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.2"
	}
}
